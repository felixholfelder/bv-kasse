{
  "name": "bv-kasse",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint .",
    "lint:eslint": "eslint . --cache",
    "format": "run-s format:*",
    "format:prettier": "prettier --write --experimental-cli src/",
    "format:oxlint": "oxlint . --fix",
    "format:eslint": "eslint . --fix --cache"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "^7.4.47",
    "firebase": "^12.14.0",
    "oxlint": "^1.69.0",
    "pinia": "^3.0.4",
    "prettier": "^3.8.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.5",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
